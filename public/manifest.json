{
  "manifest_version": 3,
  "name": "LovaLog",
  "short_name": "LovaLog",
  "description": "Lovable Backlog Manager - Manage your Lovable project features and prompts",
  "version": "1.0.0",
  "icons": {
    "16": "icon-128.png",
    "48": "icon-128.png",
    "128": "icon-128.png"
  },
  "action": {
    "default_icon": "icon-128.png",
    "default_title": "LavaLog"
  },
  "permissions": ["sidePanel", "scripting", "activeTab", "storage", "tabs", "identity", "clipboardWrite", "alarms"],
  "host_permissions": ["https://*.lovable.dev/*", "https://*.lovable.app/*"],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "content_scripts": [
    {
      "matches": ["https://*.lovable.dev/*", "https://*.lovable.app/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}